{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Stan Studio",
  "version": "1.0.0",
  "identifier": "io.stanstudio.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Stan Studio",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "A high-performance code editor built with Stan.",
    "longDescription": "Stan Studio is a lightweight, blazing-fast code editor built for developers who value speed, clarity, and control.",
    "category": "DeveloperTool",
    "copyright": "© 2026 Stan Studio"
  }
}